# Suwayomi Pipeline .gitignore

# Generated data
pipeline.log
report.json
mappings.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Temp / debugging scripts (not part of the pipeline)
check_*.py
find_*.py
test_*.py
try_*.py
fix_bleach.py
migrate_one.py
migrate_remaining.py
check_*.json
discover-sources.py
list_sources.py
mal_stacks.py
find_specific_refs.sh

# Shell helpers (user-local, not part of the pipeline)
run_pipeline.sh
run-import.sh

# OS junk
.DS_Store
Thumbs.db
Komga-Enhanced-Scrobbler/

# User config (commit lists.example.json instead)
lists.json
migrate.py
reporter.py
