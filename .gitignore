# Suwayomi Pipeline .gitignore

# Generated data
pipeline.log
report.json
mappings.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Temp / debugging scripts (root only, not tests/)
/check_*.py
/find_*.py
/test_*.py
/try_*.py
fix_bleach.py
migrate_one.py
migrate_remaining.py
check_*.json
discover-sources.py
list_sources.py

# Shell helpers (user-local, not part of the pipeline)
run_import.sh

# OS junk
.DS_Store
Thumbs.db
Komga-Enhanced-Scrobbler/

# User config (commit lists.example.json instead)
lists.json
migrate.py
